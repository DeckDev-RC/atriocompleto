# ============================================
# Agente IA Ambro — Backend Environment
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Gemini
GEMINI_API_KEY=AIzaSy...

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001

# Security
AUTH_SECURITY_SECRET=change-this-to-a-very-long-random-secret-with-32-plus-chars
AUTH_2FA_CODE_TTL_MINUTES=10
AUTH_2FA_MAX_ATTEMPTS=5
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
BULLMQ_PREFIX=ambro

# Optimus file ingestion
OPTIMUS_UPLOAD_MAX_MB=10
OPTIMUS_UPLOAD_MAX_FILES=5
OPTIMUS_UPLOADS_PER_HOUR=10
OPTIMUS_UPLOAD_STORAGE_MB=50

# Optimus conversational memory
OPTIMUS_MEMORY_SESSION_TTL_HOURS=24
OPTIMUS_MEMORY_SESSION_MAX_MESSAGES=20
OPTIMUS_MEMORY_RECALL_LIMIT=3
OPTIMUS_MEMORY_SUMMARY_MIN_MESSAGES=6
OPTIMUS_MEMORY_JOB_DELAY_MS=120000
OPTIMUS_MEMORY_RETENTION_DAYS=365

# SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-app-password
SMTP_FROM="Atrio <no-reply@example.com>"
ACCESS_REQUEST_NOTIFY_EMAIL=inbox@example.com
